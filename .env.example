# Maverics Orchestrator image tag — set to match the version you loaded with `docker load`
MAVERICS_IMAGE=maverics_base:v2026.03.2

# ── Snowflake federated-trust demo ─────────────────────────────────────────
# Used by scripts/snowflake-setup.sh and scripts/snowflake-demo.sh.

# Snowflake account URL (no trailing slash). Find it in the Snowflake UI under
# "Account Identifier" — append `.snowflakecomputing.com`.
SNOWFLAKE_ACCOUNT_URL=https://abc12345.snowflakecomputing.com

# Snowflake admin (ACCOUNTADMIN) credentials — only used by snowflake-setup
# to apply the bootstrap DDL. Once setup is done these can be removed.
SNOWFLAKE_ADMIN_USER=
SNOWSQL_PWD=

# Publicly-reachable hostname that exposes Maverics' /oauth2/jwks endpoint to
# Snowflake's network. The setup script bakes "https://<this>/oauth2/jwks"
# into EXTERNAL_OAUTH_JWS_KEYS_URL. Default lab pattern: Cloudflare Tunnel
# pointed at the local Maverics OIDC Provider. ngrok, a managed gateway, a
# CDN-fronted static jwks.json — anything publicly fetchable works.
#
# LOCAL-LAB ONLY. Don't expose a dev box this way in production — publish
# JWKS from your normal hardened public origin and point this at that host.
BEDROCK_AUTH_HOSTNAME=

# OAuth client secret used by snowflake-demo.sh to mint a JWT via
# client_credentials. Matches secrets.yaml mcp_client_cli_snowflake.client_secret.
# Not a real secret — it's the demo default everyone copies. Rotate before
# anything resembling production.
MCP_CLIENT_CLI_SNOWFLAKE_SECRET=9Q2mK7vN4xP8aL5jR3tH6mD1bF3sZcUgZ

# Optional — set to also probe the managed MCP endpoint in snowflake-demo.sh.
# Format: /api/v2/databases/<DB>/schemas/<SCHEMA>/mcp-servers/<MCP_SERVER_NAME>
SNOWFLAKE_MCP_PATH=/api/v2/databases/MAVERICS_DEMO/schemas/MCP/mcp-servers/MAVERICS_AGENT_MCP

# Optional overrides used by snowflake-demo.sh — defaults match setup.sql.
# SNOWFLAKE_ROLE=MAVERICS_DEMO_ROLE
# SNOWFLAKE_WAREHOUSE=MAVERICS_WH
